{
  "name": "portfolio-backend",
  "version": "1.0.0",
  "description": "Backend API and WebSocket Server for Portfolio",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec \"tsx server.ts\" --watch server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "nodemailer": "^6.10.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^6.4.14",
    "nodemon": "^3.1.0",
    "prisma": "^6.11.1",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
